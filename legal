<!-- =========================================================
  LEGAL PAGE — ZEN 2026 (Parfect.golfr)
  ✅ prêt à coller dans /legal.html (ou une view)
  ✅ responsive, lisible mobile, style "zen"
  ========================================================= -->

<style>
  :root{
    --pg-bg:#070A09;
    --pg-surface:rgba(255,255,255,.06);
    --pg-surface-2:rgba(255,255,255,.04);
    --pg-border:rgba(255,255,255,.10);
    --pg-text:rgba(255,255,255,.92);
    --pg-muted:rgba(255,255,255,.72);
    --pg-dim:rgba(255,255,255,.55);
    --pg-green:#00ff99;
    --pg-green-soft:rgba(0,255,153,.16);
    --pg-shadow:0 18px 50px rgba(0,0,0,.55);
    --pg-radius:18px;
    --pg-radius-lg:22px;
    --pg-max:920px;
    --pg-font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
  }

  /* Page wrapper */
  .pg-legal-page{
    min-height:100vh;
    background:
      radial-gradient(1200px 600px at 15% -10%, rgba(0,255,153,.14), transparent 55%),
      radial-gradient(900px 450px at 85% 0%, rgba(0,255,153,.10), transparent 60%),
      var(--pg-bg);
    color:var(--pg-text);
    font-family:var(--pg-font);
    padding: clamp(18px, 3vw, 36px);
  }

  .pg-legal-wrap{
    max-width: var(--pg-max);
    margin: 0 auto;
  }

  .pg-legal-topbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    margin-bottom: 16px;
  }

  .pg-legal-brand{
    display:flex;
    align-items:center;
    gap:10px;
    min-width:0;
  }
  .pg-legal-logo{
    width:34px;
    height:34px;
    border-radius:12px;
    object-fit:contain;
    background: rgba(0,0,0,.35);
    border: 1px solid var(--pg-border);
    padding:6px;
  }
  .pg-legal-brand h1{
    margin:0;
    font-size: 1.05rem;
    letter-spacing:.2px;
    font-weight: 750;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }

  .pg-legal-actions{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    justify-content:flex-end;
  }

  .pg-btn{
    appearance:none;
    border:none;
    cursor:pointer;
    font-weight:650;
    border-radius: 999px;
    padding: 10px 14px;
    font-size:.92rem;
    line-height:1;
    transition: transform .06s ease, background .2s ease, border-color .2s ease, opacity .2s ease;
    user-select:none;
  }
  .pg-btn:active{ transform: translateY(1px); }
  .pg-btn-primary{
    background: var(--pg-green);
    color:#08100C;
  }
  .pg-btn-secondary{
    background: rgba(0,0,0,.35);
    color: var(--pg-text);
    border: 1px solid var(--pg-border);
    backdrop-filter: blur(10px);
  }

  .pg-legal-hero{
    background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.035));
    border: 1px solid var(--pg-border);
    border-radius: var(--pg-radius-lg);
    box-shadow: var(--pg-shadow);
    padding: clamp(16px, 3vw, 24px);
    margin-bottom: 14px;
  }

  .pg-legal-hero h2{
    margin:0 0 6px 0;
    font-size: 1.35rem;
    font-weight: 820;
    letter-spacing:.2px;
  }
  .pg-legal-hero p{
    margin:0;
    color: var(--pg-muted);
    line-height:1.55;
    font-size: .98rem;
  }
  .pg-legal-pillrow{
    margin-top: 12px;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }
  .pg-pill{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding: 8px 10px;
    border-radius: 999px;
    border: 1px solid rgba(0,255,153,.22);
    background: rgba(0,255,153,.10);
    color: rgba(255,255,255,.92);
    font-size: .85rem;
    letter-spacing:.1px;
  }
  .pg-pill strong{ color: var(--pg-green); font-weight: 800; }

  /* Cards / sections */
  .pg-legal-grid{
    display:grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .pg-card{
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    border-radius: var(--pg-radius);
    padding: clamp(14px, 2.4vw, 18px);
    box-shadow: 0 10px 35px rgba(0,0,0,.35);
    backdrop-filter: blur(12px);
  }
  .pg-card h3{
    margin:0 0 10px 0;
    font-size: 1.05rem;
    font-weight: 800;
    color: rgba(255,255,255,.95);
    letter-spacing:.2px;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .pg-card h3 .dot{
    width:10px;
    height:10px;
    border-radius:999px;
    background: var(--pg-green);
    box-shadow: 0 0 18px rgba(0,255,153,.35);
    flex:0 0 auto;
  }
  .pg-card p, .pg-card li{
    color: var(--pg-muted);
    line-height: 1.6;
    font-size: .96rem;
  }
  .pg-card p{ margin: 0 0 10px 0; }
  .pg-card p:last-child{ margin-bottom:0; }
  .pg-card ul{
    margin: 8px 0 0 18px;
    padding:0;
  }
  .pg-card li{ margin: 6px 0; }

  .pg-legal-kv{
    display:grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-top: 10px;
  }
  .pg-kv{
    background: var(--pg-surface-2);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    padding: 12px;
  }
  .pg-kv .k{
    color: var(--pg-dim);
    font-size: .82rem;
    margin-bottom:4px;
  }
  .pg-kv .v{
    color: var(--pg-text);
    font-size: .98rem;
    font-weight: 650;
    overflow-wrap:anywhere;
  }

  /* Accordions */
  details.pg-acc{
    background: rgba(0,0,0,.20);
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 16px;
    padding: 12px 12px;
  }
  details.pg-acc + details.pg-acc{ margin-top:10px; }
  details.pg-acc summary{
    cursor:pointer;
    list-style:none;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    color: rgba(255,255,255,.92);
    font-weight: 750;
    font-size: .98rem;
  }
  details.pg-acc summary::-webkit-details-marker{ display:none; }
  .pg-acc-chevron{
    width: 28px;
    height: 28px;
    border-radius: 10px;
    display:grid;
    place-items:center;
    border:1px solid rgba(0,255,153,.25);
    background: rgba(0,255,153,.10);
    color: var(--pg-green);
    flex:0 0 auto;
    transition: transform .18s ease;
  }
  details[open] .pg-acc-chevron{ transform: rotate(180deg); }
  .pg-acc-body{
    padding-top: 10px;
    color: var(--pg-muted);
    font-size: .95rem;
    line-height:1.6;
  }

  .pg-legal-footer{
    margin-top: 16px;
    padding: 14px 2px 6px;
    color: var(--pg-dim);
    font-size: .85rem;
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    justify-content:space-between;
    align-items:center;
  }
  .pg-legal-footer a{
    color: rgba(255,255,255,.82);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.18);
  }
  .pg-legal-footer a:hover{ border-bottom-color: rgba(0,255,153,.45); }

  @media (min-width: 820px){
    .pg-legal-grid{
      grid-template-columns: 1.1fr .9fr;
      align-items:start;
    }
    .pg-legal-kv{
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="pg-legal-page">
  <div class="pg-legal-wrap">

    <!-- Topbar -->
    <div class="pg-legal-topbar">
      <div class="pg-legal-brand">
        <!-- Remplace par ton logo -->
