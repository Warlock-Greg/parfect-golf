            </p>
          </div>
        </details>

        <div style="height:12px"></div>

        <div class="pg-kv">
          <div class="k">Dernière mise à jour</div>
          <div class="v"><span id="pg-legal-updated">2026-02-08</span></div>
        </div>

      </div>
    </div>

    <!-- Footer -->
    <div class="pg-legal-footer">
      <div>© <span id="pg-legal-year">2026</span> Parfect.golfr</div>
      <div>
        <a href="#top" onclick="window.scrollTo({top:0,behavior:'smooth'}); return false;">Retour en haut</a>
      </div>
    </div>

  </div>
</div>

<script>
  // petit confort : année auto
  (function(){
    const y = new Date().getFullYear();
    const el = document.getElementById("pg-legal-year");
    if (el) el.textContent = String(y);
  })();
</script>
