      </div>

      <!-- Right: Legal -->
      <div class="pg-card">
        <h3><span class="dot"></span> Mentions légales</h3>

        <div class="pg-legal-kv">
          <div class="pg-kv">
            <div class="k">Éditeur</div>
            <div class="v">Parfect.golfr — <em>[Ton nom / Société]</em></div>
          </div>

          <div class="pg-kv">
            <div class="k">Statut</div>
            <div class="v"><em>[Auto-entrepreneur / SAS / …]</em></div>
          </div>

          <div class="pg-kv">
            <div class="k">Adresse</div>
            <div class="v"><em>[Adresse pro]</em></div>
          </div>

          <div class="pg-kv">
            <div class="k">Contact</div>
            <div class="v">contact@parfect.golfr</div>
          </div>

          <div class="pg-kv">
            <div class="k">Hébergement</div>
            <div class="v"><em>[Vercel / Netlify / OVH / Supabase / … + adresse]</em></div>
          </div>
        </div>

        <div style="height:12px"></div>

        <details class="pg-acc" open>
          <summary>
            Propriété intellectuelle
            <span class="pg-acc-chevron">⌄</span>
          </summary>
          <div class="pg-acc-body">
